{
  "name": "azure-boards-estimate",
  "version": "0.1.0",
  "private": true,
  "homepage": "./",
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "dependencies": {
    "@fluentui/react": "^8.118.13",
    "@fluentui/react-components": "^9.55.3",
    "@microsoft/signalr": "^8.0.7",
    "@reduxjs/toolkit": "^2.0.1",
    "@types/history": "^4.7.11",
    "@types/react": "^16.14.65",
    "@types/react-dom": "^16.9.25",
    "azure-devops-extension-api": "^4.244.0",
    "azure-devops-extension-sdk": "^4.0.2",
    "azure-devops-ui": "^2.167.22",
    "history": "^5.3.0",
    "immer": "^10.0.3",
    "office-ui-fabric-react": "^7.204.1",
    "react": "^16.14.0",
    "react-dom": "^16.14.0",
    "react-redux": "^7.2.9",
    "react-router-dom": "^6.20.1",
    "redux": "^5.0.0",
    "redux-saga": "^1.3.0",
    "typescript-fsa": "^3.0.0"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/node": "^20.10.4",
    "@types/webpack": "^5.28.5",
    "@types/webpack-dev-server": "^4.7.1",
    "@typescript-eslint/eslint-plugin": "^6.13.2",
    "@typescript-eslint/parser": "^6.13.2",
    "copy-webpack-plugin": "^13.0.1",
    "css-loader": "^7.1.2",
    "eslint": "^8.55.0",
    "eslint-plugin-react": "^7.33.2",
    "eslint-plugin-react-hooks": "^4.6.0",
    "html-webpack-plugin": "^5.6.4",
    "mini-css-extract-plugin": "^2.9.4",
    "sass": "^1.69.5",
    "sass-loader": "^16.0.5",
    "style-loader": "^4.0.0",
    "tfx-cli": "^0.21.3",
    "ts-loader": "^9.5.2",
    "typescript": "^5.3.3",
    "webpack": "^5.101.2",
    "webpack-cli": "^6.0.1",
    "webpack-dev-server": "^5.2.2"
  },
  "scripts": {
    "dev": "webpack serve --mode development",
    "build": "webpack --mode development",
    "build:release": "webpack --mode production",
    "preinstall": "npm i webpack -g && npm i tfx-cli -g",
    "preview": "webpack serve --mode production --open",
    "lint": "eslint src --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "lint:fix": "eslint src --ext ts,tsx --fix",
    "type-check": "tsc --noEmit",
    "test": "echo \"Tests not yet configured\"",
    "package-dev": "npm run build && tfx extension create --manifest-globs azure-devops-extension.json --overrides-file ./configs/dev.json --root ./",
    "package-test": "npm run build && tfx extension create --manifest-globs azure-devops-extension.json --overrides-file ./configs/test.json --root ./",
    "package-release": "npm run build:release && tfx extension create --manifest-globs azure-devops-extension.json --overrides-file ./configs/release.json --root ./"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  }
}
